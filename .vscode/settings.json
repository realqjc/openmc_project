{
    "python.defaultInterpreterPath": "/opt/homebrew/Caskroom/miniforge/base/envs/openmc-x86/bin/python",
    "python.terminal.activateEnvironment": false,

    "terminal.integrated.profiles.osx": {
        "zsh (openmc-x86)": {
            "path": "zsh",
            "args": [
                "-c",
                "source /opt/homebrew/Caskroom/miniforge/base/etc/profile.d/conda.sh && conda activate openmc-x86 && exec zsh"
            ]
        }
    },
    "terminal.integrated.defaultProfile.osx": "zsh (openmc-x86)",

    "terminal.integrated.automationProfile.osx": {
        "path": "zsh"
    },

    "http.proxy": "http://127.0.0.1:10792",
    "http.proxyStrictSSL": false,
    "github.copilot.advanced.proxy": "http://127.0.0.1:10792",

    "git.inputValidation": true,
    "git.useEditorAsCommitInput": false,
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.autofetch": false
}